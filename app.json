{
  "expo": {
    "name": "Relationships",
    "slug": "tend",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.joshapproved.tend",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#FAFAF7"
      },
      "predictiveBackGestureEnabled": false,
      "package": "com.joshapproved.tend",
      "permissions": [
        "android.permission.READ_CONTACTS",
        "android.permission.WRITE_CONTACTS"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "owner": "josh-approved",
    "plugins": [
      "./plugins/withGradleJvmArgs",
      "expo-sqlite",
      "expo-sharing",
      "expo-splash-screen",
      "expo-status-bar",
      "expo-font",
      "expo-notifications",
      [
        "expo-contacts",
        {
          "contactsPermission": "Relationships uses your contacts only to let you add the people you choose. Nothing leaves your device."
        }
      ],
      "expo-mail-composer"
    ],
    "extra": {
      "eas": {
        "projectId": "77c6f808-28d1-4b40-b330-77f524de01c7"
      }
    },
    "runtimeVersion": "1.0.0",
    "updates": {
      "url": "https://u.expo.dev/77c6f808-28d1-4b40-b330-77f524de01c7"
    }
  }
}
