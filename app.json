{
  "expo": {
    "name": "Relationships",
    "slug": "tend",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.joshapproved.tend",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false,
      "package": "com.joshapproved.tend"
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "owner": "josh-approved",
    "plugins": [
      "./plugins/withGradleJvmArgs",
      "expo-sqlite",
      "expo-sharing",
      "expo-splash-screen",
      "expo-status-bar",
      "expo-font",
      "expo-notifications",
      [
        "expo-contacts",
        {
          "contactsPermission": "Relationships uses your contacts only to let you add the people you choose. Nothing leaves your device."
        }
      ]
    ]
  }
}
